# AURA Frontend — 환경 변수 예시
# ─────────────────────────────────────────────────────────────
# 로컬 dev 시 .env.local 또는 .env.development 파일을 만들고 아래 값을 복사해 사용.
# .env*는 .gitignore에 의해 추적되지 않음 (.env.example 제외).

# ─── Mock 모드 ────────────────────────────────────────────────
# 'false' → 실 backend API 사용
# 그 외(미설정 / 'true') → mock 데이터 사용 (dev 안전 기본값)
# 운영 빌드는 .env.production에 VITE_USE_MOCK=false 박을 것.
VITE_USE_MOCK=true

# ─── Backend API base URL ────────────────────────────────────
# 실 API 모드에서만 사용. mock 모드에서는 무시됨.
# 두 가지 사용 케이스:
#   1. 로컬 dev (vite proxy 사용): VITE_API_BASE_URL=/api/v1
#      → vite.config.js 의 server.proxy 가 /api/v1·/socket.io 를 localhost:8000 으로 forward.
#      → CORS 우회. backend 운영 코드 안 건드림.
#   2. 운영 / 배포 환경: VITE_API_BASE_URL=https://your-domain.example.com/api/v1
#      → same origin (nginx 뒤) 이므로 CORS 무관.
VITE_API_BASE_URL=https://your-domain.example.com/api/v1
